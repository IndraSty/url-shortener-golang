# Application
APP_ENV=development
APP_PORT=8080

# Database — Neon.tech PostgreSQL
# Format: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=postgres://user:password@your-neon-host/dbname?sslmode=require
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# Cache — Upstash Redis
# Format: rediss://default:password@your-upstash-host:port
REDIS_URL=rediss://default:password@your-upstash-host:6379
REDIS_PASSWORD=your-upstash-password
REDIS_DB=0

# JWT Secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-random-64-char-hex
JWT_REFRESH_SECRET=replace-with-another-random-64-char-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Upstash QStash — async analytics queue
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key
# The public URL QStash will POST click events to (your Fly.io app URL)
QSTASH_URL=https://your-app.fly.dev/internal/analytics/ingest

# Base URL — used when generating short links
BASE_URL=http://localhost:8080